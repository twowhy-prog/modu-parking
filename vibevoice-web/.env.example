# VibeVoice 모델 경로 (HuggingFace ID 또는 로컬 경로)
REALTIME_MODEL=microsoft/VibeVoice-Realtime-0.5B
MULTISPK_MODEL=microsoft/VibeVoice-1.5B

# 기본 사용 모델 ("realtime" | "multispk")
DEFAULT_MODEL=realtime

# 서버 설정
HOST=0.0.0.0
PORT=7860

# GPU 설정 ("cuda" | "mps" | "cpu")
DEVICE=cpu

# 오디오 출력 디렉토리
AUDIO_OUTPUT_DIR=backend/audio_outputs

# HuggingFace 캐시 디렉토리 (선택)
# HF_HOME=backend/models
